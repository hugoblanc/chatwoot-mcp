# Chatwoot MCP Server Configuration

# Your Chatwoot instance URL (no trailing slash)
CHATWOOT_BASE_URL=https://app.chatwoot.com

# Authentication Method 1: API Access Token (RECOMMENDED)
# - No expiration handling needed
# - Simpler, more reliable
# - Get from: Profile Settings → Access Token
# CHATWOOT_API_TOKEN=your_api_token_here

# Authentication Method 2: JWT (Email/Password)
# - Tokens expire and need refresh
# - Requires keeping password in env for auto-refresh
# - Use only if API token doesn't work on your instance
CHATWOOT_EMAIL=your_email@example.com
CHATWOOT_PASSWORD=your_password_here
